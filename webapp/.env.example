# ============================================
# CONFIGURACIÓN DE DJANGO Y BASE DE DATOS
# ============================================

# Django Core Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,localhost,127.0.0.1,granextractor.azurewebsites.net

# Database configuration (SQL Server Azure)
DB_NAME=db-granextractor
DB_USER=adminpropifai
DB_PASSWORD=your_database_password_here
DB_HOST=granextrator.database.windows.net
DB_PORT=1433

# ============================================
# CONFIGURACIÓN CELERY (TAREAS ASÍNCRONAS)
# ============================================

# Celery Broker (SQLite temporal para desarrollo, cambiar a Redis en producción)
CELERY_BROKER_URL=sqla+sqlite:///celerydb.sqlite3

# ============================================
# CONFIGURACIÓN WEB SCRAPING
# ============================================

# User Agent para solicitudes web (personalizar según necesidad)
SCRAPING_USER_AGENT=ElGranExtractor/1.0 (+https://granextractor.azurewebsites.net)

# Delays y timeouts para evitar bloqueos
SCRAPING_DEFAULT_DELAY=3
SCRAPING_MAX_RETRIES=3
SCRAPING_TIMEOUT=30

# ============================================
# CONFIGURACIÓN AZURE (PRODUCCIÓN)
# ============================================

# Azure App Service specific
WEBSITE_HOSTNAME=granextractor.azurewebsites.net
WEBSITE_SITE_NAME=granextractor

# Azure Storage (opcional para almacenamiento de HTML)
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_STORAGE_CONTAINER=html-captures

# ============================================
# CONFIGURACIÓN DE SEGURIDAD
# ============================================

# CSRF Trusted Origins (para producción con HTTPS)
CSRF_TRUSTED_ORIGINS=https://granextractor.azurewebsites.net

# ============================================
# CONFIGURACIÓN DE MONITOREO
# ============================================

# Umbral para cambios significativos (0.0 a 1.0)
UMBRAL_CAMBIO_SIGNIFICATIVO=0.95

# Días para mantener capturas antiguas
DIAS_MANTENER_CAPTURAS=30

# ============================================
# NOTAS DE CONFIGURACIÓN
# ============================================

# Para desarrollo local:
# 1. Copiar este archivo a .env
# 2. Cambiar DEBUG=True
# 3. Ajustar credenciales de base de datos según entorno local
# 4. Para Celery en desarrollo, mantener CELERY_BROKER_URL como está
# 5. Para producción en Azure, configurar todas las variables en Application Settings

# Para producción:
# 1. Nunca usar DEBUG=True
# 2. Usar una SECRET_KEY fuerte y única
# 3. Configurar ALLOWED_HOSTS correctamente
# 4. Considerar cambiar CELERY_BROKER_URL a Redis o Azure Service Bus
# 5. Configurar almacenamiento en Azure Blob para HTML si es necesario